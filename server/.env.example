# Server Port
PORT=3001

# Frontend URL(s) for CORS — comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# Local development: individual fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kandoo
DB_USER=postgres
DB_PASS=your_postgres_password

# Production: single connection string (Render injects this automatically
# when you link a managed Postgres instance). If set, it overrides DB_* above.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Firebase Admin SDK ---
# Local: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Cloud: paste the entire service account JSON as a single env var
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
